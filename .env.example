# MarinMC Launcher — build-time environment (Vite renderer)
# Copy to ".env" and adjust. Do NOT commit your real .env.

# Public API base URL used by the packaged launcher (must end with /api).
# Example: https://api.marinmc.com/api
VITE_API_URL=https://api.marinmc.com/api

# Electron main process (optional runtime override for the same API base).
# Set in the shell/launch environment, not read from this Vite file:
#   MARINMC_API_URL=https://api.marinmc.com/api
