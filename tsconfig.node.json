{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "strict": true,
    "outDir": "dist-electron",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },
  "include": [
    "electron/**/*.ts"
  ]
}
